---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="mx-auto max-w-[800px] px-6 lg:px-10 py-16">
    <h1 class="text-2xl font-semibold tracking-tight">Privacy Policy</h1>
    <div class="mt-6 space-y-4 text-sm text-body leading-relaxed">
      <p>Chess Tournament Manager only stores data you explicitly create — tournament names, player names, and game results. We use Google Sign-In for authentication; we only access your email address and display name.</p>
      <p>Your tournament data is stored in Firebase Firestore (Google Cloud). We do not share, sell, or distribute your data to third parties.</p>
      <p>You can delete your tournaments at any time, which permanently removes that data from our database.</p>
    </div>
  </main>
</Layout>

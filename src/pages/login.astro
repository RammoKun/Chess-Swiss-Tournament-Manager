---
import Layout from '../layouts/Layout.astro';
import GoogleLogin from '../components/auth/GoogleLogin';
import AuthGuard from '../components/auth/AuthGuard';
---

<Layout>
  <AuthGuard client:load>
    <div class="flex min-h-dvh items-center justify-center" style="padding: 0 24px;">
      <div style="width: 100%; max-width: 460px;">
        <div class="mb-10 text-center">
          <a href="/" class="text-lg font-semibold tracking-tight text-ink no-underline" style="white-space: nowrap;">♟ Chess Tournament Manager</a>
        </div>
        <div
          class="rounded-lg bg-canvas text-center"
          style="padding: 40px 32px; box-shadow: 0 1px 1px rgba(0,0,0,0.02), 0 2px 2px rgba(0,0,0,0.05); border: 1px solid #ebebeb;"
        >
          <h1 class="text-2xl font-semibold tracking-tight text-ink">Welcome</h1>
          <p class="mt-2 text-base text-body">Sign in to create and manage your tournaments</p>
          <div class="mt-8 flex justify-center">
            <GoogleLogin client:load />
          </div>
        </div>
      </div>
    </div>
  </AuthGuard>
</Layout>

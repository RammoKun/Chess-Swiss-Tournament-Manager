---
import Layout from '../layouts/Layout.astro';
import TournamentView from '../components/tournament/TournamentView';
---

<Layout>
  <header class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md">
    <nav class="mx-auto flex h-full max-w-[1400px] items-center justify-between px-6 lg:px-10">
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm font-semibold tracking-tight no-underline text-ink">♟</a>
        <a href="/dashboard" class="text-xs text-body hover:text-ink transition-colors">Dashboard</a>
      </div>
      <button data-theme-toggle class="flex h-7 w-7 cursor-pointer items-center justify-center rounded-full border border-hairline bg-canvas text-mute transition-all duration-150 hover:text-ink" title="Toggle dark mode">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>
  </header>

  <main class="mx-auto max-w-[1400px] px-6 lg:px-10 py-8">
    <TournamentView client:load />
  </main>
</Layout>
